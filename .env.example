# ─────────────────────────────────────────────────────────────────────────────
# Runtime
# ─────────────────────────────────────────────────────────────────────────────
NODE_ENV=development
LOG_LEVEL=debug

# ─────────────────────────────────────────────────────────────────────────────
# Infra (local defaults match infra/docker-compose.yml)
# ─────────────────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://cacqa:cacqa@localhost:5432/cacqa
REDIS_URL=redis://localhost:6379

# S3-compatible object store (MinIO locally; swap for AWS S3 in prod)
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=cacqa-artifacts
S3_FORCE_PATH_STYLE=true

# ─────────────────────────────────────────────────────────────────────────────
# LLM provider (swap via LLM_PROVIDER)
#   - gemini : free tier, default for dev
#   - claude : paid tier, for production customers
#   - mock   : offline, for tests
# ─────────────────────────────────────────────────────────────────────────────
LLM_PROVIDER=gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# ─────────────────────────────────────────────────────────────────────────────
# Worker
# ─────────────────────────────────────────────────────────────────────────────
WORKER_CONCURRENCY=2
WORKER_HEADLESS=true
WORKER_ARTIFACT_DIR=./artifacts

# ─────────────────────────────────────────────────────────────────────────────
# API
# ─────────────────────────────────────────────────────────────────────────────
API_PORT=3001
API_CORS_ORIGIN=http://localhost:3000

# ─────────────────────────────────────────────────────────────────────────────
# Dashboard
# ─────────────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:3001
